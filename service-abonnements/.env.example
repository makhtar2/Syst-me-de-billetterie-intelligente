PORT=5060
NODE_ENV=development

# Base MySQL du service (voir PLAN-SERVICE-ABONNEMENTS.md section 1)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=billetterie_abonnements
DB_USER=root
DB_PASSWORD=

# Base utilisee par npm test, recreee a chaque execution
DB_NAME_TEST=billetterie_abonnements_test

# Doit etre IDENTIQUE au JWT_SECRET du Service Utilisateurs,
# sinon les jetons emis par lui seront rejetes ici.
JWT_SECRET=
